SESSION_SECRET=change-me-in-production-32chars

# Upstream nodes — override any entry with host.docker.internal:<port>
# to redirect that service to a locally running process instead of the container.
# Example: USER_SERVICE_NODE=host.docker.internal:5000
USER_SERVICE_NODE=host.docker.internal:5000 # user-service:5000
WORKOUT_SERVICE_NODE=workout-service:8080
METRICS_SERVICE_NODE=metrics-service:8080
FEED_SERVICE_NODE=feed-service:8080
NOTIFICATION_SERVICE_NODE=notification-service:8080